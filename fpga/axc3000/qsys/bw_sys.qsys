          <ipxact:name>bonusData</ipxact:name>
          <ipxact:displayName>bonusData</ipxact:displayName>
          <ipxact:value>bonusData 
{
   element clk_in
   {
      datum _sortIndex
      {
         value = "0";
         type = "int";
      }
   }
   element clkbr0
   {
      datum _sortIndex
      {
         value = "2";
         type = "int";
      }
   }
   element clkbr1
   {
      datum _sortIndex
      {
         value = "3";
         type = "int";
      }
   }
   element iopll
   {
      datum _sortIndex
      {
         value = "1";
         type = "int";
      }
   }
   element jtag_master
   {
      datum _sortIndex
      {
         value = "7";
         type = "int";
      }
   }
   element reset_in
   {
      datum _sortIndex
      {
         value = "4";
         type = "int";
      }
   }
