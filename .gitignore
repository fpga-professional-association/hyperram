# Quartus / Platform Designer build artifacts (fpga/axc3000).
# The SOURCE deliverables stay tracked (top.sv, pins.tcl, bw.qsf/.qpf/.sdc, sysconsole/,
# qsys/make_bw_sys.tcl, qsys/bw_sys.qsys); everything below is regenerated by
#   qsys-generate ... --quartus-project=bw --rev=bw   and   quartus_sh --flow compile bw
fpga/**/qsys/bw_sys/
fpga/**/qsys/ip/
fpga/**/output_files/
fpga/**/db/
fpga/**/incremental_db/
fpga/**/qdb/
fpga/**/dni/
fpga/**/tmp-clearbox/
*.qws
*.sof
*.pin
*.jdi
*.sld
*.smsg
*.rpt

# qsys-script scratch project (regenerated by make_bw_sys.tcl)
fpga/**/make_bw_sys.qpf
fpga/**/make_bw_sys.qsf
fpga/**/qsys/bw_sys/
